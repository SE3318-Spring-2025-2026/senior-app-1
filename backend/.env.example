# Copy this file to backend/.env to run the backend locally:
#     cp backend/.env.example backend/.env
#
# Secrets must NOT be committed — fill in real values in your local .env.

PORT=3001
JWT_SECRET=replace-with-jwt-secret
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret
FRONTEND_URL=http://localhost:5173
FRONTEND_GITHUB_RETURN_URL=http://localhost:5173/students/register
VALID_STUDENT_IDS=11070001000,11070001001,11070001002,11070001003,11070001004,11070001005,11070001006,11070001007,11070001008,11070001009

# Internal API key — gates server-to-server endpoints under /internal/*.
INTERNAL_API_KEY=internal-dev-key-replace-in-prod

# LLM provider for the AI features (PR review verification + issue
# implementation validation, issue #430). "ollama" runs locally and is the
# default; "anthropic" uses Claude API and needs credits.
LLM_PROVIDER=ollama

# Local Ollama (used when LLM_PROVIDER=ollama).
#   1. Install: https://ollama.com
#   2. `ollama pull qwen2.5-coder:1.5b`   (~1 GB, runs on CPU, ~3-5s/call,
#                                          code-aware so it reads file diffs)
#   3. `ollama serve` (or rely on the snap auto-start)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b

# Anthropic Claude key (used when LLM_PROVIDER=anthropic). Safe to leave
# placeholder when the provider is "ollama" since it's never invoked.
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
ANTHROPIC_MODEL=claude-haiku-4-5

# Database
# Default = local SQLite (fast, instant, file at backend/database.sqlite).
# To use the shared Supabase Postgres instead, set USE_LOCAL_SQLITE=0 and
# fill DATABASE_URL with the real password.
USE_LOCAL_SQLITE=1
DATABASE_URL=postgresql://postgres:<password>@db.kkvdarceomdqzeqiacfo.supabase.co:5432/postgres
SUPABASE_URL=https://kkvdarceomdqzeqiacfo.supabase.co
SUPABASE_PUBLISHABLE_KEY=replace-with-supabase-publishable-key
SUPABASE_SECRET_KEY=replace-with-supabase-secret-key
